run = "npm install && npm run dev"
entrypoint = "src/main.tsx"

[nix]
channel = "stable-24_05"

[[ports]]
localPort = 5000
externalPort = 80

[env]
# Point this at your FastAPI backend (Cloudflare Tunnel URL or public IP).
# The frontend works without it — chat and disease detection will be offline.
VITE_API_URL = "http://localhost:8000"
